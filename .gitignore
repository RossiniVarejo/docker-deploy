# Secrets — never commit real .env files
.env
**/.env

# Server-specific env overrides
infra/shared/.env.server

# TLS certificates (keep .gitkeep placeholders)
infra/apps/*/certs/*
!infra/apps/*/certs/.gitkeep
infra/reverse-proxy/certs/*
!infra/reverse-proxy/certs/.gitkeep

# Reverse-proxy runtime conf.d — files here are written by the runner at deploy time
infra/reverse-proxy/conf.d/*
!infra/reverse-proxy/conf.d/.gitkeep

# n8n local artifacts that must not enter the repo
infra/apps/n8n/plan/
infra/apps/n8n/.claude/
infra/apps/n8n/workflows/

# Evolution API — full upstream source lives in its own repo; exclude from this repo
infra/apps/evolution-api/

# macOS
.DS_Store
**/.DS_Store

# Editor
.idea/
*.swp
*.swo
