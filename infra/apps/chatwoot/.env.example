# Chatwoot — Rossini deployment
# Full variable reference: https://www.chatwoot.com/docs/self-hosted/configuration/environment-variables

# ─── Rails ────────────────────────────────────────────────────────────────────
# Generate with: rake secret
SECRET_KEY_BASE=replace_with_lengthy_secure_hex

FRONTEND_URL=https://chatwoot.example.com
FORCE_SSL=true

ENABLE_ACCOUNT_SIGNUP=false

# ─── Postgres (shared cluster) ────────────────────────────────────────────────
# Chatwoot connects to the rossini shared Postgres.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=change-this-chatwoot-db-password

# ─── Redis (external) ─────────────────────────────────────────────────────────
REDIS_URL=redis://:change-redis-password@redis-host:6379/0

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAILER_SENDER_EMAIL=chatwoot@example.com
# SMTP_ADDRESS=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local

# ─── Active Record Encryption (required for MFA) ──────────────────────────────
# Generate with: rails db:encryption:init
# ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
# ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
# ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=
