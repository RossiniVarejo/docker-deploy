# Evolution API — Rossini deployment overlay
# Copy to .env and fill in secrets before running.
#
# Full list of supported vars: https://doc.evolution-api.com/v2/en/install/env

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTHENTICATION_API_KEY=change-this-api-key

# ─── Database (shared Postgres cluster) ───────────────────────────────────────
EVOLUTION_DB_NAME=evolution
EVOLUTION_DB_USER=evolution
EVOLUTION_DB_PASSWORD=change-this-evolution-db-password

# ─── Redis ────────────────────────────────────────────────────────────────────
# Point to the shared Redis instance (or an external one)
EVOLUTION_REDIS_URI=redis://:change-redis-password@redis:6379/0

# ─── Data persistence ─────────────────────────────────────────────────────────
EVOLUTION_INSTANCES_PATH=/srv/docker-data/evolution/instances

# ─── Domain / webhook (proxied through shared nginx) ──────────────────────────
EVOLUTION_DOMAIN=evolution.example.com
