# ─── n8n — app-specific configuration ────────────────────────────────────────
# Copy to .env, fill in secrets, then run: ./rossini-runner.sh up

# Database (uses the shared Postgres cluster)
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change-this-n8n-db-password

# Encryption key — generate: openssl rand -base64 48 | tr -d '/+=' | head -c 48
# IMPORTANT: do not change after first start — stored credentials become unreadable
N8N_ENCRYPTION_KEY=change-this-to-a-random-48-char-key

# Basic-auth (disable only if using n8n's built-in user management)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-n8n-ui-password

# Domain and TLS
N8N_VERSION=latest
N8N_DOMAIN=n8n.example.com
N8N_LETSENCRYPT_DOMAIN=n8n.example.com
N8N_LETSENCRYPT_EMAIL=admin@example.com
N8N_LETSENCRYPT_STAGING=0

# Data paths
N8N_DATA_PATH=/srv/docker-data/n8n/data
N8N_FILES_PATH=/srv/docker-data/n8n/files
