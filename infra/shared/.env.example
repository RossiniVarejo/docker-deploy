# ─── Shared / cross-cutting ───────────────────────────────────────────────────
TZ=America/Sao_Paulo
RESTART=unless-stopped
SHARED_NETWORK_NAME=rossini-shared

# ─── Shared Postgres cluster ──────────────────────────────────────────────────
POSTGRES_VERSION=16-alpine
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASS=change-this-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATA_PATH=/srv/docker-data/postgres
POSTGRES_BACKUP_PATH=/srv/docker-data/postgres/backups

# ─── GLPI / MySQL ─────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=glpi
MYSQL_USER=glpi
MYSQL_PASSWORD=change-this-glpi-password
GLPI_MYSQL_VERSION=8.4
GLPI_VERSION=11.0.6
GLPI_TIMEZONE=America/Sao_Paulo

# GLPI app data
GLPI_MYSQL_DATA_PATH=/srv/docker-data/glpi/mysql
GLPI_FILES_PATH=/srv/docker-data/glpi/files
GLPI_PLUGINS_PATH=/srv/docker-data/glpi/plugins
GLPI_MARKETPLACE_PATH=/srv/docker-data/glpi/marketplace
GLPI_CONFIG_PATH=/srv/docker-data/glpi/config
GLPI_BACKUP_PATH=/srv/docker-data/glpi/backups

# GLPI Nginx / ports / TLS
NGINX_VERSION=1.27-alpine
GLPI_HTTP_PORT=8080
GLPI_HTTPS_PORT=8443
LETSENCRYPT_DOMAIN=glpi.example.com
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_STAGING=0

# GLPI jobs / retention
GLPI_CRON_INTERVAL_SECONDS=60
BACKUP_RETAIN_DAYS=30

# ─── n8n ──────────────────────────────────────────────────────────────────────
N8N_VERSION=latest
N8N_DOMAIN=n8n.example.com
N8N_HTTP_PORT=8081
N8N_HTTPS_PORT=8444
N8N_DATA_PATH=/srv/docker-data/n8n/data
N8N_FILES_PATH=/srv/docker-data/n8n/files
N8N_LETSENCRYPT_DOMAIN=n8n.example.com
N8N_LETSENCRYPT_EMAIL=admin@example.com
N8N_LETSENCRYPT_STAGING=0
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change-this-n8n-password
# Must be at least 32 random characters; generate with: openssl rand -base64 48 | tr -d '/+=' | head -c 48
# IMPORTANT: do not change after first start — stored credentials become unreadable
N8N_ENCRYPTION_KEY=change-this-to-a-random-48-char-key
# Basic-auth protection — set to false only if you enable n8n's built-in user management instead
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-n8n-ui-password
